<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Back button -->
        <Button
            android:id="@+id/btnChallengeBack"
            android:layout_width="75dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="Back"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- App label -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="Coin Budgetra"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/imgChallengeLogo"
            app:layout_constraintStart_toEndOf="@+id/btnChallengeBack"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgChallengeLogo"
            android:layout_width="45dp"
            android:layout_height="39dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/coinbudgetra" />

        <!-- Screen title -->
        <TextView
            android:id="@+id/txtChallengeFormTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Create Challenge"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnChallengeBack" />

        <!-- Expense name -->
        <EditText
            android:id="@+id/editChallengeName"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:hint="Challenge name "
            android:inputType="text"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtChallengeFormTitle" />

        <!-- Description -->
        <EditText
            android:id="@+id/editChallengeDescription"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="24dp"
            android:gravity="top"
            android:hint="Description (optional)"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editChallengeName" />

        <!-- Category -->
        <EditText
            android:id="@+id/editChallengeCategory"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="24dp"
            android:hint="Category (e.g. Food, Transport)"
            android:inputType="text"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editChallengeDescription" />

        <!-- Date section label -->
        <TextView
            android:id="@+id/labelDates"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:text="Challenge Period"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/editChallengeCategory" />

        <!-- Start date and End date row -->
        <LinearLayout
            android:id="@+id/layoutDatePickers"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelDates">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Start Date"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btnPickStartDate"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:text="DD/MM/YYYY"
                    android:textSize="10sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="End Date"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginBottom="4dp" />

                <Button
                    android:id="@+id/btnPickEndDate"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:text="DD/MM/YYYY"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Amount section label -->
        <TextView
            android:id="@+id/labelAmounts"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:text="Challenge Budget (R)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutDatePickers" />

        <!-- Min / Max row -->
        <LinearLayout
            android:id="@+id/layoutAmounts"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/labelAmounts">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Budget Maximum (R)"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:text="Max you are allowed to spend"
                    android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <EditText
                    android:id="@+id/editChallengeBudgetMax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 1000"
                    android:inputType="number"
                    android:textSize="13sp" />


            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Amount Adding (R)"
                    android:textSize="11sp"
                    android:textColor="?android:attr/textColorSecondary" />


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:text="How much you are putting in"
                    android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary" />

                <EditText
                    android:id="@+id/editChallengeAmountSaved"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 250"
                    android:inputType="number"
                    android:textSize="13sp" />


            </LinearLayout>

        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveChallenge"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_marginTop="36dp"
            android:text="Save Challenge"
            android:textSize="12sp"
            android:backgroundTint="@color/lemongreen"
            android:textColor="@color/whitesmoke"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutAmounts" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>