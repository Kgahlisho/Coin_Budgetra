<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F6FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">
   <Button
            android:id="@+id/btnCancelExpense"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="16dp"
            android:text="Cancel"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="Coin Budgetra"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/imgExpenseLogo"
            app:layout_constraintStart_toEndOf="@+id/btnCancelExpense"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgExpenseLogo"
            android:layout_width="45dp"
            android:layout_height="39dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/coinbudgetra" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardExpenseForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnCancelExpense">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                  <TextView
                    android:id="@+id/txtExpenseFormTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Expense"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="16dp"
                    android:gravity="center" />

                 <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Expense Name *"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editExpenseName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Bali Trip"
                    android:inputType="text"
                    android:textSize="13sp"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                 <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editExpenseDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Optional description"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:gravity="top"
                    android:textSize="13sp"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinnerExpenseCategory"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                   android:padding="4dp"
                    android:layout_marginBottom="14dp" />

                 <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date Range"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Start Date"
                            android:textSize="11sp"
                            android:textColor="#777777"
                            android:layout_marginBottom="4dp" />

                        <Button
                            android:id="@+id/btnExpenseStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="DD/MM/YYYY"
                            android:textSize="11sp"
                            android:backgroundTint="#E8EAF6" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="End Date"
                            android:textSize="11sp"
                            android:textColor="#777777"
                            android:layout_marginBottom="4dp" />

                        <Button
                            android:id="@+id/btnExpenseEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="DD/MM/YYYY"
                            android:textSize="11sp"
                            android:backgroundTint="#E8EAF6" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Spending Limit (R) *"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editExpenseSpendingLimit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 5000"
                    android:inputType="number"
                    android:textSize="13sp"
                   android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add Money (R)"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/editExpenseAddMoney"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Optional initial amount"
                    android:inputType="number"
                    android:textSize="13sp"
                     android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Receipts / Documents"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="4dp" />

                <Button
                    android:id="@+id/btnAttachDocument"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="📎  Upload Photo / Receipt"
                    android:textSize="12sp"
                    android:backgroundTint="#E3F2FD"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/txtDocumentCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No documents attached"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnSaveExpense"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Save Expense"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1A237E"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>


    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>