<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtChallengeName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Challenge Name"
                android:textStyle="bold"
                android:textSize="16sp" />



            <Button
                android:id="@+id/btnChallengeEdit"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="Edit"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnChallengeDelete"
                android:layout_width="78dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="Delete"
                android:textSize="10sp" />


        </LinearLayout>


        <TextView
            android:id="@+id/txtChallengeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Active"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1565C0" />

        <TextView
            android:id="@+id/txtChallengeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="No description"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtChallengeCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Category: "
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="#E0E0E0" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/txtChallengeDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DD/MM/YYYY  TO  DD/MM/YYYY"
            android:textSize="12sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/txtChallengeDaysLeft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="— Days remaining"
            android:textSize="12sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/txtChallengeAmounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Added: R0   |   Budget Max: R0"
            android:textSize="13sp"
            android:textColor="#1565C0"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtChallengeProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="0%  (R0 / R0)"
            android:textSize="12sp"
            android:textColor="#424242" />

        <ProgressBar
            android:id="@+id/progressChallenge"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:progress="0"
            android:max="100"
            android:progressTint="#1565C0"
            android:progressBackgroundTint="#E0E0E0" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add to the challenge."
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />


        <LinearLayout
            android:id="@+id/layoutAddMoney"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText

                android:id="@+id/editAddAmount"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="Enter amount (R)"
                android:inputType="numberDecimal"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:imeOptions="actionDone"
                android:maxLines="1" />


            <Button

                android:id="@+id/btnAddMoney"
                android:layout_width="90dp"
                android:layout_height="34dp"
                android:text="+ Add"
                android:textSize="12sp"
                android:textStyle="bold" />


        </LinearLayout>


    </LinearLayout>
</androidx.cardview.widget.CardView>