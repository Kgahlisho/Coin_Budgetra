<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtChallengeName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Challenge Name"
                android:textStyle="bold"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnChallengeEdit"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="Edit"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnChallengeDelete"
                android:layout_width="78dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:text="Delete"
                android:textSize="10sp" />

        </LinearLayout>


        <TextView
            android:id="@+id/txtChallengeDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="No description"
            android:textSize="12sp" />


        <TextView
            android:id="@+id/txtChallengeCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Category: General"
            android:textSize="12sp" />


        <View
            android:layout_width="match_parent"
            android:layout_height="9dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:background="#E0E0E0" />


        <TextView
            android:id="@+id/txtChallengeDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DD/MM/YYYY  to   DD/MM/YYYY"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtChallengeAmounts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Min: R0   |   Max: R0"
            android:textSize="13sp"
            android:textColor="#1565C0"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>