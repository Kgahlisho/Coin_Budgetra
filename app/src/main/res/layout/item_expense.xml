<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="1dp"
    app:cardCornerRadius="0dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Expense Name -->
        <TextView
            android:id="@+id/txtExpenseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="—"
            android:textSize="12sp"
            android:textColor="#1A1A2E"
            android:textStyle="bold" />

        <!-- Category -->
        <TextView
            android:id="@+id/txtExpenseCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="—"
            android:textSize="12sp"
            android:textColor="#444444" />

        <!-- Total Budget -->
        <TextView
            android:id="@+id/txtExpenseBudget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="R0"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:textStyle="bold" />

        <!-- Documents -->
        <TextView
            android:id="@+id/txtExpenseDocuments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="None"
            android:textSize="12sp"
            android:textColor="#555555" />

        <!-- Options -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnExpenseEdit"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Edit"
                android:textSize="9sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#1A237E"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnExpenseDelete"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Delete"
                android:textSize="9sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:backgroundTint="#B71C1C"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>